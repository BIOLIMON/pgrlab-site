{
  // Cloudflare Workers deploy via: npx wrangler deploy
  // We add a tiny Worker to serve SPA routes (e.g. /team) with index.html fallback.
  "name": "pgrlab-site",
  "compatibility_date": "2026-02-17",
  "main": "src/worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
